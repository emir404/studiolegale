{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/save-conversation.py\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Saving conversation…"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/scripts/save-conversation.py\" 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
